{
  "name": "doota",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "auth:schema": "auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply doota --local",
    "db:migrate:remote": "wrangler d1 migrations apply doota --remote",
    "db:studio": "drizzle-kit studio",
    "gen": "wrangler types",
    "reset-admin": "node scripts/reset-admin.mjs",
    "deploy": "pnpm run build && wrangler deploy",
    "email:dev": "pnpm dlx @better-svelte-email/cli dev --dir src/lib/client/email"
  },
  "devDependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@better-auth/utils": "0.4.2",
    "@better-fetch/fetch": "1.3.1",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@libsql/client": "latest",
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.19.13",
    "auth": "https://pkg.pr.new/auth@10221",
    "better-auth": "~1.6.23",
    "better-call": "1.3.7",
    "bits-ui": "^2.16.3",
    "cloudflare": "^7.0.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "layerchart": "2.0.0-next.48",
    "mode-watcher": "^1.1.0",
    "phosphor-svelte": "^3.1.0",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.3.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "wrangler": "^4.110.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@better-svelte-email/components": "^2.1.1",
    "@better-svelte-email/server": "^2.1.1",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "runed": "^0.37.1",
    "uqr": "^0.1.3"
  }
}
