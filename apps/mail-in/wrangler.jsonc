{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  // Inbound mail Worker. KEEP this name — the Email Routing catch-all rule
  // (domains.remote.ts → MAIL_IN_WORKER_NAME) points at it. Owns email() +
  // the inbound-queue consumer only; outbound + cron are in doota-mail-jobs.
  "name": "doota-mail-inbound",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_als", "nodejs_compat"],
  // Deploys wipe dashboard-set plaintext vars unless kept (secrets survive).
  "keep_vars": true,
  "main": "src/index.ts",
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "r2_buckets": [
    {
      "binding": "MAIL_RAW",
      "bucket_name": "doota-mail-raw"
    }
  ],
  // Per-user mail event hub (lives in doota-mail-jobs): DSN-fallback bounces
  // notify the sending user's live stream through it.
  "durable_objects": {
    "bindings": [
      {
        "name": "MAIL_EVENTS",
        "class_name": "MailEventHub",
        "script_name": "doota-mail-jobs"
      }
    ]
  },
  "queues": {
    // email() enqueues to MAIL_QUEUE; this Worker also consumes it.
    "producers": [
      {
        "binding": "MAIL_QUEUE",
        "queue": "doota-mail-inbound"
      }
    ],
    "consumers": [
      {
        "queue": "doota-mail-inbound",
        "max_batch_size": 10,
        "max_retries": 5
      }
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "doota",
      "database_id": "f60f6cbf-7936-4169-90a8-a8555793aa8b",
      "migrations_dir": "../../drizzle"
    }
  ]
}
