{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "doota",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_als", "nodejs_compat"],
  // Workers Builds runs `wrangler deploy` on every push, and by default that
  // DELETES any dashboard-set plaintext variable not present in this file.
  // keep_vars preserves them. (Encrypted secrets always survive deploys.)
  "keep_vars": true,
  // Wrapper entry: re-exports the SvelteKit fetch handler (adapter-cloudflare's
  // _worker.js). This Worker serves the app and PRODUCES to the mail queues; the
  // asynchronous mail handlers (email/queue/scheduled) live in the standalone
  // `doota-mail` Worker (wrangler.mail.jsonc), which owns the queue consumers,
  // the Email Routing catch-all, and the cron sweep.
  "main": "./.svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare",
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "r2_buckets": [
    {
      "binding": "MAIL_RAW",
      "bucket_name": "doota-mail-raw",
      "remote": true,
    },
  ],
  // The app only PRODUCES to the mail queues (send.remote / draft send enqueue to
  // MAIL_OUT_QUEUE). The CONSUMERS + cron trigger live in the `doota-mail` Worker
  // (wrangler.mail.jsonc) — a queue can bind to only one consumer Worker.
  "queues": {
    "producers": [
      {
        "binding": "MAIL_QUEUE",
        "queue": "doota-mail-inbound",
      },
      {
        "binding": "MAIL_OUT_QUEUE",
        "queue": "doota-mail-outbound",
      },
    ],
  },
  "send_email": [
    {
      "name": "EMAIL_SENDER",
      "remote": true,
    },
  ],
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "custom_domain": true,
      "pattern": "mail.doota.dev",
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "doota",
      "database_id": "f60f6cbf-7936-4169-90a8-a8555793aa8b",
      // Migrations live at the workspace root (shared with the mail Workers).
      "migrations_dir": "../../drizzle",
    },
  ],
  // Better Auth secondary storage: a fast read cache in front of D1 for sessions
  // + verification values (see src/lib/server/auth/kv-secondary-storage.ts). Local
  // dev simulates this by binding name; before deploying, create the namespace
  // (`wrangler kv namespace create AUTH_KV`) and paste the returned id below.
  "kv_namespaces": [
    {
      "binding": "AUTH_KV",
      "id": "9f20318e054a4f56a03e594eedd32c60",
    },
  ],
  // Per-user mail event hub (lives in doota-mail-jobs). The failedSends
  // query.live generator long-polls it so failure toasts are event-driven —
  // the DB is read only on stream connect and on an actual failure.
  "durable_objects": {
    "bindings": [
      {
        "name": "MAIL_EVENTS",
        "class_name": "MailEventHub",
        "script_name": "doota-mail-jobs",
      },
    ],
  },
}
