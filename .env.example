# Drizzle
DATABASE_URL=file:local.db

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# One-time token that gates the /setup genesis wizard. Leave unset to disable
# the web wizard entirely (use `pnpm reset-admin` on the CLI instead).
SETUP_TOKEN=""

# Cloudflare: a SCOPED API Token (Bearer) — NOT the Global API Key, and no
# account email. Store as a Worker secret in production.
APP_CLOUDFLARE_ACCOUNT_ID=""

APP_CLOUDFLARE_API_TOKEN=""

# Name of the deployed mail-in Worker the catch-all routing rule targets.
MAIL_IN_WORKER_NAME=""

# Bearer secret the cron trigger presents to POST /api/cron (maintenance sweeps).
CRON_SECRET=""
